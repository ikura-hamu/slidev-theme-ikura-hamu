{
  "name": "@ikura-hamu/slidev-theme-ikura-hamu",
  "version": "0.0.0",
  "type": "module",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "repository": {
    "url": "https://github.com/ikura-hamu/slidev-theme-ikura-hamu"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "license": "MIT",
  "scripts": {
    "build": "slidev build example.md",
    "dev": "slidev example.md --open",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png",
    "export-md": "slidev export example.md --format md --output examples/light/README.md && slidev export example.md --format md --dark --output examples/dark/README.md"
  },
  "dependencies": {
    "@slidev/types": "^52.15.2"
  },
  "devDependencies": {
    "@slidev/cli": "^52.15.2",
    "@slidev/client": "^52.15.2",
    "playwright-chromium": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-slidev": "^1.0.5",
    "unocss": "^66.6.8",
    "vue": "^3.5.34"
  },
  "//": "Learn more: https://sli.dev/guide/write-theme.html",
  "slidev": {
    "colorSchema": "both",
    "defaults": {
      "fonts": {
        "sans": "Noto Sans JP",
        "mono": "Fira Code"
      }
    }
  }
}
